GCP_ACCOUNT=your-email@gmail.com
GCP_PROJECT_ID=your-project-id
GCP_PROJECT_NAME=AI Agentic Demo
GCP_REGION=us-central1
GCP_BILLING_ACCOUNT=your-billing-account-id

VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Force ADK to use Vertex AI instead of AI Studio
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

LIVE_DEMO_URL=ai-agentic.techcloudup.com
GITHUB_REPO=github.com/your-username/ai-agentic
